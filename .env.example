# ═══════════════════════════════════════════════════════
# .env — Personalized Learning AI Environment Configuration
# Copy this file and fill in your real values.
# NEVER commit the real .env to version control.
# ═══════════════════════════════════════════════════════

# ── Server ──
PORT=8000
ENVIRONMENT=development

# ── Security ──
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production

# ── Supabase ──
# Get from: https://app.supabase.com → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# ── Google Gemini ──
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash-lite

# ── CORS (add your frontend origins) ──
# ALLOWED_ORIGINS=["http://localhost:5500","https://your-production-domain.com"]
